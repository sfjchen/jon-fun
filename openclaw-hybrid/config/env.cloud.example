OPENCLAW_HOME=/home/openclaw/.openclaw
OPENCLAW_CONFIG_PATH=/home/openclaw/.openclaw/openclaw.json
OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_HOOKS_TOKEN=replace-with-random-64-char-token

# OpenRouter model routing
OPENROUTER_API_KEY=sk-or-your-key

# Outlook / Graph bridge
GRAPH_TENANT_ID=replace-with-tenant-id
GRAPH_CLIENT_ID=replace-with-client-id
GRAPH_CLIENT_SECRET=replace-with-client-secret
GRAPH_USER_ID=replace-with-mailbox-user-id-or-upn
GRAPH_WEBHOOK_CLIENT_STATE=replace-with-long-random-string

# Power Automate callback URL for approval flow
PA_APPROVAL_WEBHOOK_URL=https://prod-xx.westus.logic.azure.com/workflows/...
PA_APPROVAL_WEBHOOK_TOKEN=replace-with-random-token

# BlueBubbles endpoint (Mac-hosted)
BLUEBUBBLES_SERVER_URL=https://mac-relay.example.com
BLUEBUBBLES_PASSWORD=replace-with-bluebubbles-password

# Notification fallback
TELEGRAM_BOT_TOKEN=replace-with-bot-token
TELEGRAM_CHAT_ID=replace-with-chat-id

# Optional urgent escalation
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
URGENT_CALL_TO_NUMBER=+15555550123
