{
  "name": "game-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "verify:meditations-pdf": "tsx scripts/verify-meditations-pdf.ts",
    "verify:epub-fixture": "tsx scripts/generate-minimal-epub.ts && tsx scripts/verify-epub-fixture.ts",
    "verify:reader-fixtures": "tsx scripts/generate-minimal-epub.ts && tsx scripts/verify-reader-fixtures.ts",
    "verify:witcher-epub": "tsx scripts/verify-witcher-epub-structure.ts",
    "verify:daily-learn-csv": "tsx scripts/verify-daily-learn-csv.ts",
    "seed:reader-portable": "tsx scripts/seed-reader-portable-from-fixtures.ts",
    "build:reader-curated": "tsx scripts/build-reader-library-curated.ts",
    "patch:tinad-wiki-section1": "tsx scripts/patch-tinad-wiki-section1-portable.ts",
    "smoke:reader-suggest-chapter": "tsx scripts/smoke-reader-suggest-chapter.ts",
    "smoke:reader-communal-list": "tsx scripts/reader-communal-summarize.ts",
    "sync:reader-communal-fixtures": "tsx scripts/sync-reader-communal-from-fixtures.ts",
    "db:migrations": "supabase migration list --linked",
    "db:push": "supabase db push --linked --yes",
    "seed:jeopardy-mendochino": "tsx scripts/seed-jeopardy-mendochino.ts",
    "verify:jeopardy-realtime": "tsx scripts/verify-jeopardy-realtime.ts",
    "verify:jeopardy-buzzer": "tsx scripts/verify-jeopardy-buzzer.ts",
    "verify:notes-triggers": "tsx scripts/verify-notes-triggers.ts",
    "verify:notes-attachments": "tsx scripts/verify-notes-attachments.ts",
    "verify:notes-agent-actions": "tsx scripts/verify-notes-agent-actions.ts",
    "verify:notes-export": "tsx scripts/verify-notes-export.ts",
    "verify:notes-tables": "tsx scripts/verify-notes-tables.ts",
    "verify:notes": "npm run verify:notes-triggers && npm run verify:notes-attachments && npm run verify:notes-tables && npm run verify:notes-export",
    "test:e2e": "playwright test",
    "playwright:install": "playwright install chromium",
    "test:e2e:ci": "CI=1 playwright test",
    "test:e2e:deployment": "PLAYWRIGHT_SKIP_WEBSERVER=1 CI=1 playwright test",
    "test:e2e:notes": "CI=1 playwright test e2e/notes.spec.ts e2e/notes-comprehensive.spec.ts e2e/notes-export.spec.ts e2e/notes-search.spec.ts e2e/notes-restore.spec.ts e2e/notes-attachments.spec.ts e2e/notes-tables.spec.ts e2e/notes-sync-race.spec.ts e2e/notes-security.spec.ts e2e/notes-visual.spec.ts e2e/notes-viewport.spec.ts --project=chromium --grep-invert screenshot",
    "test:e2e:notes-mobile": "CI=1 playwright test e2e/notes-mobile.spec.ts --project=mobile-chromium --grep-invert screenshot",
    "test:e2e:notes-visual": "PLAYWRIGHT_SKIP_WEBSERVER=1 CI=1 playwright test e2e/notes-visual.spec.ts --project=chromium",
    "test:e2e:notes-sync": "PLAYWRIGHT_SKIP_WEBSERVER=1 CI=1 playwright test e2e/notes-sync.spec.ts --project=chromium",
    "test:e2e:notes-lookup": "PLAYWRIGHT_SKIP_WEBSERVER=1 CI=1 playwright test e2e/notes-lookup.spec.ts --project=chromium",
    "test:e2e:notes-deploy": "PLAYWRIGHT_SKIP_WEBSERVER=1 CI=1 playwright test e2e/notes.spec.ts e2e/notes-search.spec.ts e2e/notes-export.spec.ts e2e/notes-restore.spec.ts e2e/notes-attachments.spec.ts --project=chromium --grep-invert screenshot",
    "smoke:notes-llm": "tsx scripts/smoke-notes-llm.ts",
    "test:e2e:ui": "playwright test --ui",
    "openclaw:bridge": "node openclaw-hybrid/scripts/bridge-server.mjs",
    "openclaw:dispatch": "node openclaw-hybrid/scripts/dispatcher.mjs",
    "openclaw:graph:upsert": "node openclaw-hybrid/scripts/graph-subscription.mjs upsert",
    "openclaw:graph:delete": "node openclaw-hybrid/scripts/graph-subscription.mjs delete"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.81.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-bubble-menu": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/markdown": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.3.1",
    "dommatrix": "^0.1.1",
    "fast-xml-parser": "^5.7.1",
    "fflate": "^0.8.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "katex": "^0.17.0",
    "marked": "^18.0.5",
    "next": "^16.2.9",
    "node-html-parser": "^7.1.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "5.4.296",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tsx": "^4.20.5",
    "typescript": "^5"
  }
}
